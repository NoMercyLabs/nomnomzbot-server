# =============================================================================
# NomNomzBot Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit the .env file to source control.
#
# For local development: cp .env.example .env && docker-compose up
# The defaults below are safe for local dev — change secrets before deploying.
#
# For running without Docker (dotnet run), dev defaults come from appsettings.json.
# =============================================================================

# --- Postgres ----------------------------------------------------------------
POSTGRES_USER=
POSTGRES_PASSWORD=

# --- Auth --------------------------------------------------------------------
JWT_SECRET=
# Generate a strong key for production: openssl rand -base64 32
JWT_ISSUER=
JWT_AUDIENCE=
ENCRYPTION_KEY=

# --- Twitch ------------------------------------------------------------------
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BOT_USERNAME=

# --- Redis -------------------------------------------------------------------
# Connection string passed to the API container
REDIS_CONNECTION_STRING=redis:6379

# --- Spotify -----------------------------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Discord -----------------------------------------------------------------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- YouTube -----------------------------------------------------------------
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=

# --- Optional: Azure TTS -----------------------------------------------------
# AZURE_TTS_API_KEY=
# AZURE_TTS_REGION=westeurope

# --- Optional: ElevenLabs ----------------------------------------------------
# ELEVENLABS_API_KEY=

# --- Host port overrides (change if defaults are in use on your machine) -----
# API_HTTP_PORT=5080
# API_HTTPS_PORT=5081
# POSTGRES_PORT=5432
# REDIS_PORT=6379

# --- Deployment mode ---------------------------------------------------------
# self-hosted = single streamer; saas = multi-tenant hosted
DEPLOYMENT_MODE=self-hosted

# --- Cloudflare Tunnel -------------------------------------------------------
# Get token from: https://one.dash.cloudflare.com/ → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=
