# =============================================================================
# NomercyBot Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit the .env file to source control.
# =============================================================================

# --- Database ----------------------------------------------------------------
DATABASE__CONNECTIONSTRING=Host=localhost;Database=nomercybot;Username=postgres;Password=changeme

# --- Authentication ----------------------------------------------------------
JWT__SECRET=your-secret-key-at-least-32-characters-long
JWT__ISSUER=NomercyBot
JWT__AUDIENCE=NomercyBot

# --- Twitch ------------------------------------------------------------------
TWITCH__CLIENTID=your-twitch-client-id
TWITCH__CLIENTSECRET=your-twitch-client-secret
TWITCH__REDIRECTURI=http://localhost:5000/api/v1/auth/callback

# --- Redis -------------------------------------------------------------------
REDIS__CONNECTIONSTRING=localhost:6379

# --- Docker Compose Overrides (used by docker-compose.yml) -------------------
POSTGRES_USER=nomercybot
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
JWT_SECRET=your-secret-key-at-least-32-characters-long
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTE_KEY=
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret
