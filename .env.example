# =============================================================================
# NomercyBot Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit the .env file to source control.
#
# For local development: cp .env.example .env && docker-compose up
# The defaults below are safe for local dev — change secrets before deploying.
#
# For running without Docker (dotnet run), dev defaults come from appsettings.json.
# =============================================================================

# --- Postgres ----------------------------------------------------------------
POSTGRES_USER=nomercybot
POSTGRES_PASSWORD=nomercybot_dev

# --- Auth --------------------------------------------------------------------
JWT_SECRET=dev-secret-key-at-least-32-characters-long!!
# Generate a strong key for production: openssl rand -base64 32
JWT_ISSUER=nomercybot
JWT_AUDIENCE=nomercybot
ENCRYPTION_KEY=ZGV2LWVuY3J5cHRpb24ta2V5LWZvci1sb2NhbC1kZXY=

# --- Twitch ------------------------------------------------------------------
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret
TWITCH_BOT_USERNAME=your-bot-username

# --- Redis -------------------------------------------------------------------
# Connection string passed to the API container
REDIS_CONNECTION_STRING=redis:6379

# --- Optional: Azure TTS -----------------------------------------------------
# AZURE_TTS_API_KEY=your-azure-tts-api-key
# AZURE_TTS_REGION=westeurope

# --- Optional: ElevenLabs ----------------------------------------------------
# ELEVENLABS_API_KEY=your-elevenlabs-api-key

# --- Host port overrides (change if defaults are in use on your machine) -----
# API_HTTP_PORT=5080
# API_HTTPS_PORT=5081
# POSTGRES_PORT=5432
# REDIS_PORT=6379
