# =============================================================================
# NomercyBot Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit the .env file to source control.
#
# For local development: cp .env.example .env && docker-compose up
# The defaults below are safe for local dev — change secrets before deploying.
# =============================================================================

# --- Database ----------------------------------------------------------------
# Used when running locally WITHOUT Docker (dotnet run)
ConnectionStrings__DefaultConnection=Host=localhost;Database=nomercybot;Username=nomercybot;Password=nomercybot_dev
ConnectionStrings__Redis=localhost:6379

# --- Authentication ----------------------------------------------------------
Jwt__Secret=dev-secret-key-at-least-32-characters-long!!
Jwt__Issuer=NomercyBot
Jwt__Audience=NomercyBot

# --- Twitch ------------------------------------------------------------------
Twitch__ClientId=your-twitch-client-id
Twitch__ClientSecret=your-twitch-client-secret
Twitch__BotUsername=your-bot-username
Twitch__RedirectUri=http://localhost:5000/api/v1/auth/callback

# --- Docker Compose Overrides (used by docker-compose.yml) -------------------
# These are substituted into docker-compose.yml at runtime.
# They do NOT need to match the ASP.NET Core config key format above.
POSTGRES_USER=nomercybot
POSTGRES_PASSWORD=nomercybot_dev
JWT_SECRET=dev-secret-key-at-least-32-characters-long!!
# Generate a strong key for production: openssl rand -base64 32
ENCRYPTION_KEY=ZGV2LWVuY3J5cHRpb24ta2V5LWZvci1sb2NhbC1kZXY=
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret
TWITCH_BOT_USERNAME=your-bot-username
# Redis connection string passed to the API container (defaults to redis:6379 if not set)
REDIS_CONNECTION_STRING=redis:6379
# Host port overrides — change these if the default ports are in use on your machine
# API_HTTP_PORT=5080
# API_HTTPS_PORT=5081
# POSTGRES_PORT=5432
# REDIS_PORT=6379
