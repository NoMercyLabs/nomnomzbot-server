{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=nomercybot;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD"
  },
  "Database": {
    "MaxPoolSize": 20,
    "MinPoolSize": 5
  },
  "Jwt": {
    "Secret": "YOUR_JWT_SECRET_MIN_32_CHARS",
    "Issuer": "nomercybot",
    "Audience": "nomercybot",
    "ExpiryMinutes": 60
  },
  "Encryption": {
    "Key": "YOUR_BASE64_ENCODED_32_BYTE_KEY"
  },
  "Twitch": {
    "ClientId": "",
    "ClientSecret": "",
    "BotUsername": "",
    "RedirectUri": "http://localhost:5000/api/v1/auth/twitch/callback"
  },
  "Azure": {
    "Tts": {
      "ApiKey": "",
      "Region": "westeurope"
    }
  },
  "ElevenLabs": {
    "ApiKey": ""
  },
  "Cors": {
    "Origins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "AllowedHosts": "*"
}
